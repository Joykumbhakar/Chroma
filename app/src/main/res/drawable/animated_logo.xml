    <!-- Animators for Path 1 (D) -->
    <target android:name="path_1">
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <!-- Draw stroke over 2.5 seconds -->
                <objectAnimator
                    android:propertyName="trimPathEnd"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:duration="2500"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <!-- Fade in fill after stroke -->
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:startOffset="2500"
                    android:duration="1000"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <!-- Fade out stroke border -->
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.0"
                    android:startOffset="2500"
                    android:duration="1000" />
            </set>
        </aapt:attr>
    </target>

    <!-- Animators for Path 2 (J) -->
    <target android:name="path_2">
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <!-- Draw stroke starting 400ms delayed -->
                <objectAnimator
                    android:propertyName="trimPathEnd"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:startOffset="400"
                    android:duration="2500"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <!-- Fade in fill after stroke (2500 + 400 = 2900) -->
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:startOffset="2900"
                    android:duration="1000"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <!-- Fade out stroke border -->
                <objectAnimator
                    android:propertyName="strokeAlpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.0"
                    android:startOffset="2900"
                    android:duration="1000" />
            </set>
